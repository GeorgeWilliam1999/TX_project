+\*****************************************************************************/
+#pragma once
+
+namespace Extrapolators {
+  namespace NRKExtrapolatorConstants {
+    // Number of Runge-Kutta-Nyström stages (classical 4-stage scheme).
+    constexpr int n_stages = 4;
+
+    // Stage offsets c_i used to advance the state slope before evaluating
+    // the next field-dependent acceleration. Identical to the in-tree
+    // RungeKuttaNystromExtrapolator::fillStages convention.
+    constexpr float stage_offsets[n_stages] = {0.f, 0.5f, 0.5f, 1.f};
+  } // namespace NRKExtrapolatorConstants
+} // namespace Extrapolators
