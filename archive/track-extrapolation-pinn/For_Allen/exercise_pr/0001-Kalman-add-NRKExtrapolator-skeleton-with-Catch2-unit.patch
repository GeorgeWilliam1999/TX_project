diff --git a/test/unit_tests/generic/src/TestNRKExtrapolator.cu b/test/unit_tests/generic/src/TestNRKExtrapolator.cu
new file mode 100644
index 000000000000..1dcbb6a508fb
--- /dev/null
+++ b/test/unit_tests/generic/src/TestNRKExtrapolator.cu
@@ -0,0 +1,149 @@
+/*****************************************************************************\
+* (c) Copyright 2026 CERN for the benefit of the LHCb Collaboration           *
+*                                                                             *
+* This software is distributed under the terms of the Apache License          *
+* version 2 (Apache-2.0), copied verbatim in the file "LICENSE".              *
+*                                                                             *
+* In applying this licence, CERN does not waive the privileges and immunities *
+* granted to it by virtue of its status as an Intergovernmental Organization  *
+* or submit itself to any jurisdiction.                                       *
+\*****************************************************************************/
+#if __has_include(<catch2/catch.hpp>)
+// Catch2 v2
+#include <catch2/catch.hpp>
+namespace Catch {
+  using Detail::Approx;
+}
+#else
+// Catch2 v3
+#include <catch2/catch_approx.hpp>
+#include <catch2/catch_test_macros.hpp>
+#endif
+
+#include <NRKExtrapolator.cuh>
+
+using Catch::Approx;
+using Extrapolators::NRKExtrapolator;
+using Extrapolators::State;
+
+namespace {
+  // Tolerance for FP32 accumulation over a single step.
+  constexpr float k_tol = 1e-5f;
+
+  inline State make_state(float x, float y, float z, float tx, float ty, float qop)
+  {
+    State s;
+    s.x = x;
+    s.y = y;
+    s.z = z;
+    s.tx = tx;
+    s.ty = ty;
+    s.qop = qop;
+    return s;
+  }
+} // namespace
+
+// A2 - zero-field straight-line propagation.
+//
+// With B = 0 the gamma function vanishes, all RK stages are zero, and the
+// propagator must reduce to the analytic straight line:
+//   x' = x + tx * dz, y' = y + ty * dz, tx' = tx, ty' = ty, z' = z + dz.
+TEST_CASE("unit_tests.nrk_extrapolator.zero_field_straight_line", "[NRKExtrapolator]")
+{
+  const float3 B = make_float3(0.f, 0.f, 0.f);
+  const float dz = 100.f;
+  const float qop = 1e-3f;
+
+  State s = make_state(1.0f, 2.0f, 0.0f, 0.1f, -0.05f, qop);
+  const State s0 = s;
+  NRKExtrapolator::make_step(s, dz, B);
+
+  REQUIRE(s.x == Approx(s0.x + s0.tx * dz).margin(k_tol));
+  REQUIRE(s.y == Approx(s0.y + s0.ty * dz).margin(k_tol));
+  REQUIRE(s.z == Approx(s0.z + dz).margin(k_tol));
+  REQUIRE(s.tx == Approx(s0.tx).margin(k_tol));
+  REQUIRE(s.ty == Approx(s0.ty).margin(k_tol));
+  REQUIRE(s.qop == Approx(s0.qop).margin(0.f));
+}
+
+// A4 - sign symmetry.
+//
+// Under (x, tx) -> (-x, -tx) and B_y -> -B_y the equations of motion are
+// invariant up to overall sign, so the propagated x and tx flip sign while
+// y, ty remain unchanged. Tested at zero field where the symmetry is exact
+// independently of B.
+TEST_CASE("unit_tests.nrk_extrapolator.sign_symmetry_zero_field", "[NRKExtrapolator]")
+{
+  const float3 B = make_float3(0.f, 0.f, 0.f);
+  const float dz = 50.f;
+  const float qop = 1e-3f;
+
+  State sa = make_state(0.5f, 0.3f, 0.0f, 0.02f, 0.01f, qop);
+  State sb = make_state(-0.5f, 0.3f, 0.0f, -0.02f, 0.01f, qop);
+
+  NRKExtrapolator::make_step(sa, dz, B);
+  NRKExtrapolator::make_step(sb, dz, B);
+
+  REQUIRE(sa.x == Approx(-sb.x).margin(k_tol));
+  REQUIRE(sa.tx == Approx(-sb.tx).margin(k_tol));
+  REQUIRE(sa.y == Approx(sb.y).margin(k_tol));
+  REQUIRE(sa.ty == Approx(sb.ty).margin(k_tol));
+  REQUIRE(sa.z == Approx(sb.z).margin(k_tol));
+}
+
+// A1 - q/p row of the Jacobian.
+//
+// At zero field qop is a pure passenger: the propagated qop must equal the
+// input regardless of the other state components. This is the diagonal
+// element of the q/p row of the Jacobian.
+TEST_CASE("unit_tests.nrk_extrapolator.qop_invariant", "[NRKExtrapolator]")
+{
+  const float3 B = make_float3(0.1f, -0.2f, 0.05f);
+  const float dz = 25.f;
+
+  for (const float qop : {-1e-3f, 0.f, 1e-3f, 5e-3f}) {
+    State s = make_state(0.0f, 0.0f, 0.0f, 0.01f, -0.02f, qop);
+    NRKExtrapolator::make_step(s, dz, B);
+    REQUIRE(s.qop == Approx(qop).margin(0.f));
+  }
+}
+
+// A3 - linearity in qop at first order.
+//
+// In zero field the slope update vanishes for any qop. With non-zero field
+// and a small step we verify that the leading qop-dependence of (tx, ty) is
+// linear: doubling qop doubles the slope change to within the
+// quadratic-in-dz remainder.
+TEST_CASE("unit_tests.nrk_extrapolator.qop_linearity_small_step", "[NRKExtrapolator]")
+{
+  const float3 B = make_float3(0.0f, 0.5f, 0.0f);
+  const float dz = 1.f;
+  const float qop1 = 1e-4f;
+  const float qop2 = 2e-4f;
+
+  State s1 = make_state(0.f, 0.f, 0.f, 0.f, 0.f, qop1);
+  State s2 = make_state(0.f, 0.f, 0.f, 0.f, 0.f, qop2);
+
+  NRKExtrapolator::make_step(s1, dz, B);
+  NRKExtrapolator::make_step(s2, dz, B);
+
+  // Slope deflections should scale linearly with qop at lowest order.
+  REQUIRE(s2.tx == Approx(2.f * s1.tx).epsilon(1e-3));
+  REQUIRE(s2.ty == Approx(2.f * s1.ty).epsilon(1e-3));
+}
+
+// Smoke - dz = 0 must be a no-op.
+TEST_CASE("unit_tests.nrk_extrapolator.zero_step_is_identity", "[NRKExtrapolator]")
+{
+  const float3 B = make_float3(0.3f, -0.1f, 0.05f);
+  State s = make_state(1.f, -2.f, 10.f, 0.05f, 0.03f, 1e-3f);
+  const State s0 = s;
+  NRKExtrapolator::make_step(s, 0.f, B);
+
+  REQUIRE(s.x == Approx(s0.x).margin(0.f));
+  REQUIRE(s.y == Approx(s0.y).margin(0.f));
+  REQUIRE(s.z == Approx(s0.z).margin(0.f));
+  REQUIRE(s.tx == Approx(s0.tx).margin(0.f));
+  REQUIRE(s.ty == Approx(s0.ty).margin(0.f));
+  REQUIRE(s.qop == Approx(s0.qop).margin(0.f));
+}
