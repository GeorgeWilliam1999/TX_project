+* or submit itself to any jurisdiction.                                       *
+\*****************************************************************************/
+#pragma once
+
+#include <BackendCommon.h>
+#include <ExtrapolatorCommon.cuh>
+#include <NRKExtrapolatorConstants.cuh>
+
+namespace Extrapolators {
+
+  /**
+   * NRKExtrapolator
+   *
+   * Neural-Runge-Kutta-Nyström extrapolator (research prototype).
+   *
+   * Surface API mirrors RungeKuttaNystromExtrapolator but takes the magnetic
+   * field vector directly as a function argument rather than looking it up in
+   * a field grid. This makes the extrapolator independently testable without
+   * a MagneticField::Magfield instance and provides the exact integration
+   * surface that a learnable (MLP-augmented) body will replace in a
+   * follow-up merge request.
+   *
+   * The current body is a faithful restatement of
+   * RungeKuttaNystromExtrapolator::make_fast_step with the field-grid lookup
+   * factored out, so behaviour is numerically equivalent to the existing
+   * Nyström step under identical inputs. No algorithm wrapper, no sequence
+   * wiring, no property hooks: this header is unreachable from any current
+   * Allen sequence and therefore cannot affect throughput or physics
+   * performance until it is explicitly wired in.
+   */
+  struct NRKExtrapolator {
+
+  private:
+    __host__ __device__ inline static float2 gamma(const float2 t, const float3 B)
+    {
+      const float norm = sqrtf(1.f + t.x * t.x + t.y * t.y);
+      return make_float2(
+        norm * (t.x * t.y * B.x - (1.f + t.x * t.x) * B.y + t.y * B.z),
+        norm * ((1.f + t.y * t.y) * B.x - t.x * t.y * B.y - t.x * B.z));
+    }
+
+    __host__ __device__ inline static void fillStages(
+      float2 k[NRKExtrapolatorConstants::n_stages],
+      const float2 t,
+      const float qop,
+      const float3 B,
+      const float dz)
+    {
+      k[0] = gamma(t, B);
+      k[0].x *= qop;
+      k[0].y *= qop;
+      for (int stage = 1; stage < NRKExtrapolatorConstants::n_stages; stage++) {
+        const float c = NRKExtrapolatorConstants::stage_offsets[stage];
+        const float2 t_eff = make_float2(t.x + k[stage - 1].x * dz * c, t.y + k[stage - 1].y * dz * c);
+        k[stage] = gamma(t_eff, B);
+        k[stage].x *= qop;
+        k[stage].y *= qop;
+      }
+    }
+
+  public:
+    /**
+     * Single Runge-Kutta-Nyström step with a directly-supplied field vector B.
+     *
+     * Equivalent to RungeKuttaNystromExtrapolator::make_fast_step evaluated
+     * with B = field at the step midpoint. The decoupling of the field
+     * lookup is the only behavioural difference from the in-tree RKN.
+     */
+    __host__ __device__ static inline void make_step(State& state, const float dz, const float3 B)
+    {
+      const float2 tn = make_float2(state.tx, state.ty);
+
+      float2 k[NRKExtrapolatorConstants::n_stages];
+      fillStages(k, tn, state.qop, B, dz);
+
+      const float2 dRn = make_float2(
+        tn.x * dz + (k[0].x + k[1].x + k[2].x) * (dz * dz * (1.f / 6.f)),
+        tn.y * dz + (k[0].y + k[1].y + k[2].y) * (dz * dz * (1.f / 6.f)));
+      const float2 dTn = make_float2(
+        (k[0].x + 2.f * k[1].x + 2.f * k[2].x + k[3].x) * (dz * (1.f / 6.f)),
+        (k[0].y + 2.f * k[1].y + 2.f * k[2].y + k[3].y) * (dz * (1.f / 6.f)));
+
+      state.x += dRn.x;
+      state.y += dRn.y;
+      state.z += dz;
+      state.tx += dTn.x;
+      state.ty += dTn.y;
+    }
+  };
+
+} // namespace Extrapolators
