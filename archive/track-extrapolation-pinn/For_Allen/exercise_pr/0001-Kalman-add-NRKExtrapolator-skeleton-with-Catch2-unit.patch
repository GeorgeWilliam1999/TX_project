index 23a90218ee37..978ecfc0f43d 100644
--- a/test/unit_tests/CMakeLists.txt
+++ b/test/unit_tests/CMakeLists.txt
@@ -16,7 +16,7 @@ add_definitions(-D${TARGET_DEFINITION})
 
